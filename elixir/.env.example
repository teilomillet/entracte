# Copy this file to `.env` and fill in local runner values.
# `.env` is ignored by git; do not commit real tokens.

# Linear controls what work the runner sees.
LINEAR_API_KEY=

# Use only the slug after `/project/`, not the full Linear URL.
# Example URL: https://linear.app/acme/project/entracte-abc123/issues
# Example value: LINEAR_PROJECT_SLUG=entracte-abc123
LINEAR_PROJECT_SLUG=

# Optional: watch several Linear projects from one runner when they share the
# same repository, workflow, Codex account, and runner machine.
# Example value: LINEAR_PROJECT_SLUGS=entracte-abc123,client-a-def456
# When this is set, it is preferred over LINEAR_PROJECT_SLUG.
LINEAR_PROJECT_SLUGS=

# Use `me` for a per-person runner. Leave blank for a shared runner that can see
# all ready issues in the configured project.
LINEAR_ASSIGNEE=me

# Optional: used by the `gitlab_coverage` app-server primitive.
# `GITLAB_PROJECT_ID` may be a numeric project ID or namespace/project path.
GITLAB_API_ENDPOINT=https://gitlab.com/api/v4
GITLAB_API_TOKEN=
GITLAB_PROJECT_ID=

# Local filesystem path where per-issue workspaces are created.
SYMPHONY_WORKSPACE_ROOT=~/code/entracte-workspaces

# Repository cloned into each issue workspace.
SOURCE_REPO_URL=https://github.com/teilomillet/entracte.git

# Optional Codex binary override.
CODEX_BIN=codex

# Optional Sari app-server launcher for Claude Code, OpenCode, or future
# backend-neutral runtime profiles.
# Example value: SARI_BIN=/Users/alice/Code/sari/scripts/sari_app_server
SARI_BIN=

# Optional defaults for `mix symphony.start`.
# SYMPHONY_PORT=4000
# SYMPHONY_LOGS_ROOT=log

# First-time setup:
#   1. Set LINEAR_API_KEY above, or export it in the shell.
#   2. Run `mix symphony.bootstrap`.
# Bootstrap discovers Linear projects, writes the project slug when unambiguous,
# installs the Linear dispatch labels, creates required workflow states such as
# Human Review, Merging, and Rework, installs the issue template, creates saved
# Linear views for Ready, Paused, and project workflow states, favorites them
# under a Symphony sidebar folder, and runs the smoke check.
#
# Default dispatch guardrail:
#   agent-ready  -> explicit permission for the runner to spend Codex credits
#   agent-paused -> hard stop for new and active work
#
# `mix symphony.start` also checks for missing dispatch labels and issue
# templates before it starts the runner.

# For isolated runner processes, create ignored profile env files such as
# `.env.entracte` and `.env.client-a`.
#
# Use profiles when projects need different repositories, workflows, Codex
# accounts, workspace roots, ports, or logs.
#
# To launch every profile with one command, define the profile list in `.env`:
# SYMPHONY_PROFILES=entracte,client-a
#
# Then run:
#   mix symphony.start
#
# Symphony will start each profile as a separate OS process. Set a distinct
# SYMPHONY_PORT in each `.env.<profile>` if you want a web dashboard for each.

# Optional SSH config for remote worker mode.
# SYMPHONY_SSH_CONFIG=
